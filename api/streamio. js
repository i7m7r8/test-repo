const { createRouter } = require('@stremio-addon/sdk');
const { AddonBuilder } = require('@stremio-addon/sdk');
const axios = require('axios');

// ---------- Configuration ----------
// Set these environment variables in Vercel:
// TPB_API_URL – the base URL of your hosted ThePirateBay API (e.g., https://your-tpb-api.com)
// OMDB_API_KEY – your API key from omdbapi.com (optional but recommended for title lookup)
const TPB_API_URL = process.env.TPB_API_URL;
const OMDB_API_KEY = process.env.OMDB_API_KEY;

// ---------- Manifest ----------
const manifest = {
    id: 'community.yourusername.tpbaddon',
    version: '1.0.0',
    name: 'ThePirateBay Streams',
    description: 'Provides torrent streams from ThePirateBay',
    resources: ['stream'],
    types: ['movie', 'series'],
    catalogs: []
};

// ---------- Builder ----------
const builder = new AddonBuilder(manifest);

// Helper: Extract infoHash from magnet link (if needed)
function extractInfoHash(magnet) {
    const match = magnet.match(/btih:([a-zA-Z0-9]+)/i);
    return match ? match[1] : null;
}

// ---------- Stream Handler ----------
builder.defineStreamHandler(async ({ type, id }) => {
    console.log(`[TPB] Request for ${type} with IMDb ID: ${id}`);

    // Basic validation
    if (!TPB_API_URL) {
        console.error('TPB_API_URL not set');
        return { streams: [] };
    }

    try {
        // Step 1: Get movie/show title from IMDb ID using OMDB
        let title = null;
        let year = null;

        if (OMDB_API_KEY) {
            const omdbRes = await axios.get(`http://www.omdbapi.com/?i=${id}&apikey=${OMDB_API_KEY}`);
            if (omdbRes.data.Response === 'True') {
                title = omdbRes.data.Title;
                year = omdbRes.data.Year;
                console.log(`[OMDB] Found: ${title} (${year})`);
            } else {
                console.warn(`[OMDB] No data for ${id}`);
            }
        }

        // If OMDB fails or no key, fallback: use a placeholder or try to extract from id
        // You could also use a different metadata service, or simply search by IMDb ID (rarely works)
        if (!title) {
            // Fallback: just use the IMDb ID as search term (very low chance of success)
            title = id.replace('tt', '');
            year = '';
        }

        // Step 2: Build search query for TPB
        const searchTerm = encodeURIComponent(`${title} ${year}`.trim());
        // TPB API endpoint: /search/{search_term}/{page}/
        // We'll use page 1 for simplicity
        const tpbUrl = `${TPB_API_URL}/search/${searchTerm}/1/`;

        console.log(`[TPB] Fetching: ${tpbUrl}`);
        const tpbRes = await axios.get(tpbUrl, { timeout: 8000 });

        if (!tpbRes.data || !Array.isArray(tpbRes.data)) {
            console.warn('[TPB] Unexpected response format');
            return { streams: [] };
        }

        // Step 3: Map torrents to Stremio streams
        const streams = tpbRes.data.map(torrent => {
            // The API response fields may vary; adjust according to actual data
            // Common fields: name, info_hash, seeds, leeches, size, magnet_link
            const infoHash = torrent.info_hash || (torrent.magnet_link ? extractInfoHash(torrent.magnet_link) : null);
            if (!infoHash) return null; // skip if no hash

            // Build a nice title for Stremio UI
            const streamTitle = [
                torrent.name,
                `📁 ${torrent.size || 'Unknown'}`,
                `⬆️ ${torrent.seeds || 0}`,
                `⬇️ ${torrent.leeches || 0}`
            ].join(' | ');

            return {
                name: torrent.name,               // short name
                title: streamTitle,                // detailed info shown in UI
                infoHash: infoHash.toLowerCase(),  // required for torrent streams
                fileIdx: 0,                         // usually the first file
                sources: torrent.magnet_link ? [torrent.magnet_link] : [] // optional fallback
            };
        }).filter(s => s !== null); // remove nulls

        console.log(`[TPB] Returning ${streams.length} streams`);
        return { streams };

    } catch (error) {
        console.error('[TPB] Error in stream handler:', error.message);
        return { streams: [] };
    }
});

// ---------- Serverless Export ----------
const router = createRouter(builder.getInterface());

module.exports = async (req, res) => {
    // Vercel passes (req, res) – just forward to the router
    await router(req, res);
};
